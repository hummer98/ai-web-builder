{
  "model": "openrouter/anthropic/claude-sonnet-4.6",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "google/gemini-2.5-pro-preview-06-05": {
          "name": "Gemini 2.5 Pro"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp",
        "--headless",
        "--url",
        "http://localhost:5173/preview/"
      ]
    },
    "log-reader": {
      "type": "local",
      "command": [
        "node",
        "--import",
        "tsx",
        "/app/container/log-reader-mcp/src/index.ts"
      ]
    },
    "nano-banana": {
      "type": "local",
      "command": [
        "npx",
        "nano-banana-mcp"
      ],
      "env": {
        "GEMINI_API_KEY": "{env:GEMINI_API_KEY}"
      }
    }
  }
}