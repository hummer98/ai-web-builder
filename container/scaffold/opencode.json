{
  "provider": {
    "openrouter": {
      "api_key": "{env:OPENROUTER_API_KEY}",
      "models": {
        "google/gemini-2.5-pro-preview-06-05": {
          "name": "Gemini 2.5 Pro"
        }
      }
    }
  },
  "model": {
    "default": "openrouter/google/gemini-2.5-pro-preview-06-05"
  },
  "mcp": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp", "--headless", "--url", "http://localhost:5173"]
    },
    "log-reader": {
      "command": "node",
      "args": ["--import", "tsx", "../container/log-reader-mcp/src/index.ts"]
    }
  }
}
