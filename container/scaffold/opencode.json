{
  "model": "openrouter/anthropic/claude-sonnet-4.6",
  "instructions": [],
  "provider": {
    "openrouter": {
      "options": {},
      "models": {}
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp",
        "--headless",
        "--browser",
        "chromium"
      ]
    },
    "log-reader": {
      "type": "local",
      "command": [
        "node",
        "--import",
        "tsx",
        "/app/container/log-reader-mcp/src/index.ts"
      ]
    },
    "nano-banana": {
      "type": "local",
      "command": [
        "npx",
        "nano-banana-mcp"
      ]
    }
  }
}