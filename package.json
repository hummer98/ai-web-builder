{
  "name": "ai-web-builder",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:agent dev:vite dev:hono",
    "dev:all": "npm-run-all --parallel dev:*",
    "dev:agent": "cd container/agent-server && npx tsx watch src/index.ts",
    "dev:opencode": "cd workspace && opencode serve :4096",
    "dev:vite": "npm run dev --prefix workspace",
    "dev:hono": "cd workspace && npx tsx watch functions/api/index.ts"
  },
  "devDependencies": {
    "npm-run-all2": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
